# Sanity CMS — get these from sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional — server-only token for previewing drafts (read-only)
SANITY_API_TOKEN=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# SEO — paste the token from Google Search Console (Settings → Ownership
# verification → HTML tag). Leave blank until you set that up.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Forms — pick one
RESEND_API_KEY=
# FORMSPREE_ENDPOINT=

# Careers form — where applications go and which sender Resend uses
HR_EMAIL=Hrd@jlmorison.com
# Must be on a domain verified inside Resend (e.g. careers@jlmorison.com)
RESEND_FROM_EMAIL=careers@jlmorison.com

# Contact-us form — comma-separated recipients + sender (verified domain)
CONTACT_TO_EMAILS=customercare@jlmorison.com,info@jlmorison.com
CONTACT_FROM_EMAIL=website@jlmorison.com

# Video storage (only if using GCS instead of YouTube/Vimeo embeds)
GCS_BUCKET_NAME=
